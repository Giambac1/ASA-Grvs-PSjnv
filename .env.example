# ---------------------------------------------------------------------------
# Deliveroo.js connection
# ---------------------------------------------------------------------------
# Local server: http://localhost:8080
# Course server: https://deliveroojs.bears.disi.unitn.it
HOST=http://localhost:8080

# JWT token. Leave empty on first run: connect with NAME only, the server
# emits a fresh token (printed in the agent logs). Save it here so that
# reconnections re-attach to the same in-game agent.
TOKEN=

# Agent name used on first connection (when TOKEN is empty).
NAME=agentA

# Name of the teammate agent (used by the team protocol handshake to
# recognize which "hello" message belongs to our second agent).
TEAMMATE_NAME=agentB

# ---------------------------------------------------------------------------
# Strategy selection
# ---------------------------------------------------------------------------
# One of: greedy-nearest | reward-distance | delivery-threshold | mission-aware
STRATEGY=reward-distance

# Label attached to logs/results (e.g. the scenario name: 26c1_3).
RUN_LABEL=dev

# ---------------------------------------------------------------------------
# PDDL planner (optional at runtime)
# ---------------------------------------------------------------------------
# Set to "true" to register the PDDL go_to plan in the plan library.
PDDL_ENABLED=false
# When PDDL_ENABLED=true, also try a full PDDL pickup-and-deliver plan
# before the normal BDI pickup plan. Off by default for performance, not
# correctness: it defers to the BDI mission plans whenever a mission
# constraint is active, and its putdown reuses the same safety selection.
PDDL_DELIVERY_ENABLED=false
# Keep PDDL bounded: oversized/slow planner calls fall back to BFS.
PDDL_MAX_TILES=1600
PDDL_TIMEOUT_MS=2500
# Use PDDL only where it may be worth the online-solver overhead.
PDDL_MIN_PATH_LENGTH=10
PDDL_AVOID_WHILE_CARRYING=true
# Online solver used by @unitn-asa/pddl-client (planning-as-a-service):
PAAS_HOST=https://solver.planning.domains:5001
PAAS_PATH=/package/dual-bfws-ffparser/solve

# ---------------------------------------------------------------------------
# LLM provider (optional — Agent B falls back to deterministic parsing)
# ---------------------------------------------------------------------------
# OpenAI-compatible endpoint (course LiteLLM gateway, see lab8):
LITELLM_BASE_URL=https://llm.bears.disi.unitn.it/v1
LITELLM_API_KEY=
LLM_MODEL=llama-3.3-70b-lmstudio

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_DIR=experiments/logs
RESULTS_DIR=experiments/results
